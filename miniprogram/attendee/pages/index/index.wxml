<view class="container">
  <view class="exhibition-banner">
    <image src="{{currentExhibition.coverImage}}" mode="aspectFill" class="banner-image"></image>
    <view class="banner-info">
      <text class="exhibition-title">{{currentExhibition.exhibitionName}}</text>
      <text class="exhibition-time">{{currentExhibition.startTime}} - {{currentExhibition.endTime}}</text>
      <text class="exhibition-venue">{{currentExhibition.venue}}</text>
    </view>
  </view>

  <view class="quick-actions">
    <view class="action-item" bindtap="goToScan">
      <image src="/images/scan-large.png" mode="aspectFit"></image>
      <text>扫码建联</text>
    </view>
    <view class="action-item" bindtap="goToVirtualRoom">
      <image src="/images/virtual-large.png" mode="aspectFit"></image>
      <text>虚拟展位</text>
    </view>
    <view class="action-item" bindtap="goToRecommend">
      <image src="/images/recommend-large.png" mode="aspectFit"></image>
      <text>智能推荐</text>
    </view>
    <view class="action-item" bindtap="goToConnections">
      <image src="/images/connections-large.png" mode="aspectFit"></image>
      <text>我的建联</text>
    </view>
  </view>

  <view class="recommendations">
    <view class="section-header">
      <text class="section-title">为您推荐</text>
      <text class="section-more" bindtap="goToRecommend">查看更多 ></text>
    </view>
    <scroll-view scroll-x class="recommend-list">
      <view class="recommend-item" wx:for="{{recommendations}}" wx:key="merchantId" bindtap="goToMerchantDetail" data-id="{{item.merchantId}}">
        <image src="{{item.logo}}" mode="aspectFill" class="merchant-logo"></image>
        <text class="merchant-name">{{item.merchantName}}</text>
        <text class="merchant-industry">{{item.industry}}</text>
        <view class="match-score">
          <text class="score">{{item.matchScore}}</text>
          <text class="score-label">匹配度</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="live-rooms">
    <view class="section-header">
      <text class="section-title">正在直播</text>
      <text class="section-more" bindtap="goToVirtualRoom">查看更多 ></text>
    </view>
    <view class="live-list">
      <view class="live-item" wx:for="{{liveRooms}}" wx:key="roomId" bindtap="goToLiveRoom" data-room-id="{{item.roomId}}">
        <image src="{{item.coverImage}}" mode="aspectFill" class="live-cover"></image>
        <view class="live-info">
          <text class="live-title">{{item.roomName}}</text>
          <text class="live-merchant">{{item.merchantName}}</text>
          <view class="live-status">
            <view class="live-dot"></view>
            <text class="live-text">直播中</text>
            <text class="viewer-count">{{item.visitorCount}}人观看</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="activities">
    <view class="section-header">
      <text class="section-title">精彩活动</text>
    </view>
    <view class="activity-list">
      <view class="activity-item" wx:for="{{activities}}" wx:key="activityId" bindtap="goToActivity" data-id="{{item.activityId}}">
        <view class="activity-left">
          <text class="activity-name">{{item.activityName}}</text>
          <text class="activity-time">{{item.startTime}}</text>
          <text class="activity-type">{{item.activityType}}</text>
        </view>
        <view class="activity-right">
          <text class="activity-status {{item.status}}">{{item.statusText}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="statistics">
    <view class="stat-item">
      <text class="stat-number">{{statistics.totalConnections}}</text>
      <text class="stat-label">建联数</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{statistics.scanCount}}</text>
      <text class="stat-label">扫码数</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{statistics.score}}</text>
      <text class="stat-label">积分</text>
    </view>
  </view>
</view>
