<view class="container">
  <view class="user-header">
    <image src="{{userInfo.avatar}}" mode="aspectFill" class="avatar"></image>
    <view class="user-info">
      <text class="username">{{userInfo.nickName}}</text>
      <text class="user-phone">{{userInfo.phoneNumber || '未绑定手机'}}</text>
    </view>
    <button class="edit-btn" bindtap="editProfile">编辑</button>
  </view>

  <view class="stats-section">
    <view class="stat-card">
      <text class="stat-number">{{userInfo.connectionCount || 0}}</text>
      <text class="stat-label">建联数</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{userInfo.scanCount || 0}}</text>
      <text class="stat-label">扫码数</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{userInfo.score || 0}}</text>
      <text class="stat-label">积分</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{userInfo.signDays || 0}}</text>
      <text class="stat-label">签到天数</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToMaterials">
      <image src="/images/materials.png" mode="aspectFit" class="menu-icon"></image>
      <text class="menu-text">我的物料</text>
      <text class="menu-count">{{materialCount}}个</text>
      <image src="/images/arrow-right.png" mode="aspectFit" class="arrow-icon"></image>
    </view>
    <view class="menu-item" bindtap="goToFavorite">
      <image src="/images/favorite.png" mode="aspectFit" class="menu-icon"></image>
      <text class="menu-text">我的收藏</text>
      <text class="menu-count">{{favoriteCount}}个</text>
      <image src="/images/arrow-right.png" mode="aspectFit" class="arrow-icon"></image>
    </view>
    <view class="menu-item" bindtap="goToActivities">
      <image src="/images/activity.png" mode="aspectFit" class="menu-icon"></image>
      <text class="menu-text">参与活动</text>
      <text class="menu-count">{{activityCount}}个</text>
      <image src="/images/arrow-right.png" mode="aspectFit" class="arrow-icon"></image>
    </view>
    <view class="menu-item" bindtap="goToPrizes">
      <image src="/images/prize.png" mode="aspectFit" class="menu-icon"></image>
      <text class="menu-text">我的奖品</text>
      <text class="menu-count">{{prizeCount}}个</text>
      <image src="/images/arrow-right.png" mode="aspectFit" class="arrow-icon"></image>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToSettings">
      <image src="/images/settings.png" mode="aspectFit" class="menu-icon"></image>
      <text class="menu-text">设置</text>
      <image src="/images/arrow-right.png" mode="aspectFit" class="arrow-icon"></image>
    </view>
    <view class="menu-item" bindtap="goToHelp">
      <image src="/images/help.png" mode="aspectFit" class="menu-icon"></image>
      <text class="menu-text">帮助中心</text>
      <image src="/images/arrow-right.png" mode="aspectFit" class="arrow-icon"></image>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <image src="/images/about.png" mode="aspectFit" class="menu-icon"></image>
      <text class="menu-text">关于我们</text>
      <image src="/images/arrow-right.png" mode="aspectFit" class="arrow-icon"></image>
    </view>
  </view>

  <view class="sign-in-section" wx:if="{{!signedToday}}">
    <text class="section-title">每日签到</text>
    <view class="sign-in-calendar">
      <view class="day-item {{item.signed ? 'signed' : ''}}" wx:for="{{signCalendar}}" wx:key="day">
        <text class="day-text">{{item.day}}</text>
        <text class="day-status">{{item.signed ? '已签' : '未签'}}</text>
      </view>
    </view>
    <button class="btn btn-primary sign-in-btn" bindtap="signIn">立即签到</button>
  </view>

  <view class="signed-section" wx:if="{{signedToday}}">
    <image src="/images/signed-success.png" mode="aspectFit" class="signed-icon"></image>
    <text class="signed-text">今日已签到，连续签到{{userInfo.signDays}}天</text>
    <text class="score-earned">获得 +10 积分</text>
  </view>

  <view class="edit-profile-modal" wx:if="{{showEditModal}}">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">编辑资料</text>
        <view class="close-btn" bindtap="closeEditModal">×</view>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">昵称</text>
          <input 
            class="form-input" 
            placeholder="请输入昵称" 
            value="{{editForm.nickName}}" 
            bindinput="onNicknameChange"
            maxlength="20"
          />
        </view>
        <view class="form-item">
          <text class="form-label">手机号</text>
          <input 
            class="form-input" 
            placeholder="请输入手机号" 
            value="{{editForm.phoneNumber}}" 
            bindinput="onPhoneChange"
            type="number"
            maxlength="11"
          />
        </view>
        <view class="form-item">
          <text class="form-label">公司</text>
          <input 
            class="form-input" 
            placeholder="请输入公司名称" 
            value="{{editForm.company}}" 
            bindinput="onCompanyChange"
            maxlength="50"
          />
        </view>
        <view class="form-item">
          <text class="form-label">职位</text>
          <input 
            class="form-input" 
            placeholder="请输入职位" 
            value="{{editForm.position}}" 
            bindinput="onPositionChange"
            maxlength="30"
          />
        </view>
      </view>
      <view class="modal-actions">
        <button class="btn btn-secondary" bindtap="closeEditModal">取消</button>
        <button class="btn btn-primary" bindtap="saveProfile">保存</button>
      </view>
    </view>
  </view>
</view>
