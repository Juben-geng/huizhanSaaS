page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  min-height: 100vh;
  padding-bottom: 100rpx;
}

.btn {
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background-color: #1890ff;
  color: #ffffff;
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #333333;
}

.btn-accent {
  background-color: #ff6b6b;
  color: #ffffff;
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid #1890ff;
  color: #1890ff;
}

.btn-small {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
}

.btn.active {
  opacity: 0.6;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-more {
  font-size: 24rpx;
  color: #1890ff;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-state text {
  font-size: 28rpx;
  color: #999999;
}

.empty-hint {
  font-size: 24rpx !important;
  color: #cccccc !important;
  margin-top: 10rpx;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 24rpx;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: #ffffff;
  border-radius: 16rpx;
  width: 90%;
  max-height: 80vh;
  z-index: 1000;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eeeeee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.close-btn {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
  overflow-y: auto;
}

.modal-actions {
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
  border-top: 1rpx solid #eeeeee;
}

.modal-actions .btn {
  flex: 1;
  margin: 0 10rpx;
}

.tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  background-color: #e6f7ff;
  color: #1890ff;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin: 10rpx;
}

.tag.active {
  background-color: #1890ff;
  color: #ffffff;
}

.tag-add {
  border: 2rpx dashed #1890ff;
  background-color: transparent;
}
