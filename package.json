{
  "name": "exhibition-saas-system",
  "version": "2.1.0",
  "description": "会展智能建联SaaS系统 - 四端架构：参会者小程序+商家端+主办方后台+平台总后台",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run admin:dev\"",
    "server:dev": "cd backend && npm run dev",
    "server:build": "cd backend && npm run build",
    "admin:dev": "cd admin/platform && npm run dev",
    "admin:build": "cd admin/platform && npm run build",
    "miniapp:dev": "cd attendee-miniapp && npm run dev",
    "install:all": "npm install && cd backend && npm install && cd ../admin/platform && npm install && cd ../attendee-miniapp && npm install",
    "lint": "eslint . --ext .js,.vue,.ts",
    "test": "jest"
  },
  "keywords": [
    "exhibition",
    "saas",
    "wechat-miniapp",
    "b2b",
    "smart-matching"
  ],
  "author": "会展智能建联SaaS",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
